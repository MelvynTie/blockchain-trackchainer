{
  "name": "blockchain-for-ledgerit",
  "version": "3.0.0",
  "description": "A Blockchain sample NodeJS application for the inventory industry.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.x",
    "npm": ">=9.x"
  },
  "type": "module",
  "main": "./server/server.js",
  "scripts": {
    "start": "nodemon --ignore chaincode/ ./server/server.js --inspect",
    "build": "npm-run-all build:server",
    "build:server": "echo 'No build step required'",
    "serve": "cross-env NODE_ENV=production node ./server/server.js",
    "server": "npm run serve",
    "dev": "node ./server/server.js",
    "lint": "eslint .",
    "autofix": "eslint --fix .",
    "clean": "rimraf -rf ./dist ./bin"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "body-parser": "1.20.2",
    "compression": "1.7.4",
    "concurrently": "^9.1.2",
    "cookie-parser": "1.4.6",
    "core-js": "^3.39.0",
    "cross-env": "7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "eslint-plugin-async-await": "0.0.0",
    "eslint-plugin-import": "^2.31.0",
    "express": "4.19.2",
    "express-rate-limit": "^7.5.0",
    "fabric-ca-client": "2.2.20",
    "fabric-network": "^2.2.20",
    "helmet": "^8.0.0",
    "i18n": "0.15.1",
    "json-style-converter": "1.0.3",
    "morgan": "1.10.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "4.1.5",
    "pug": "^3.0.3",
    "rimraf": "^6.0.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {}
}
